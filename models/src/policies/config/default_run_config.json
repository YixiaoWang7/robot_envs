{
  "version": 1,
  "feature": {
    "features": [
      {
        "key": "actions",
        "shape": [7],
        "source_type": "hdf5",
        "paths": ["actions"],
        "camera_names": [],
        "history": 0,
        "future": 15
      },
      {
        "key": "state",
        "shape": [16],
        "source_type": "hdf5",
        "paths": [
          "obs/robot0_eef_pos",
          "obs/robot0_eef_quat",
          "obs/robot0_gripper_qpos",
          "obs/robot0_joint_pos"
        ],
        "camera_names": [],
        "history": 0,
        "future": 0
      },
      {
        "key": "env_state",
        "shape": [45],
        "source_type": "hdf5",
        "paths": ["obs/object"],
        "camera_names": [],
        "history": 0,
        "future": 0
      },
      {
        "key": "images",
        "shape": [3, 256, 256],
        "source_type": "video",
        "paths": [],
        "camera_names": ["agentview", "robot0_eye_in_hand"],
        "history": 0,
        "future": 0
      }
    ]
  },
  "dataset": {
    "data_dir": "/mnt/ssd/yixiao/cg/test/mixed",
    "cameras": ["agentview", "robot0_eye_in_hand"],
    "split": { "val_fraction": 0.05, "split_seed": 0 },
    "sampling": {
      "k_passes": 4,
      "active_window_shards": 2,
      "locality_block_size": 16,
      "predecode_next_block": true,
      "frame_cache_max_entries": 12000,
      "profile_timing": true,
      "profile_every_samples": 500,
      "log_stall_ms": 200.0
    },
    "loader": { "batch_size": 64, "num_workers": 16, "prefetch_factor": 4 }
  },
  "processor": {
    "normalization_type": "minmax",
    "normalize_actions": true,
    "normalize_states": true,
    "add_task_indices": true,
    "obj_to_idx": { "cross": 0, "cube": 1, "cylinder": 2 },
    "container_to_idx": { "bin": 0, "cup": 1, "plate": 2 }
  },
  "model": {
    "vision_model_size": "small",
    "raw_image_size": 256,
    "crop": true,
    "crop_size": 224,
    "crop_is_random": true,
    "freeze_vision_backbone": true,
    "pooled_dim": 64,
    "fusion_num_layers": 4,
    "fusion_num_heads": 8,
    "fusion_ff_dim": 512,
    "fusion_dropout": 0.1,
    "fusion_mask_type": "none",
    "camera_feature_combine": "concat",
    "num_query_tokens": 2,
    "down_dims": [128, 256, 512]
  },
  "algo": {
    "path_type": "linear",
    "scheduler_type": "uniform",
    "solver_type": "euler",
    "num_inference_steps": 10,
    "guidance_scale": 1.0,
    "velocity_clamp": null,
    "sigma_min": 0.0001,
    "sigma_schedule": "constant",
    "ot_reg": 0.05,
    "time_eps": 0.0,
    "logit_normal_loc": 0.0,
    "logit_normal_scale": 1.0,
    "dense_jump_density": 2.0
  },
  "train": {
    "device": "",
    "lr": 0.0001,
    "weight_decay": 0.0001,
    "amp": true,
    "grad_clip_norm": 1.0,
    "num_steps": 50000,
    "num_data_warmup": 50,
    "log_every": 50,
    "eval_every": 500,
    "eval_num_batches": 10,
    "eval_best_of_k": 4,
    "save_every": 100
  },
  "logging": {
    "out_dir": "runs/robot_flow_train",
    "wandb": {
      "enabled": true,
      "project": "robot_flow_training",
      "entity": "yixiao_wang",
      "run_name": "exp1_v2"
    }
  }
}
